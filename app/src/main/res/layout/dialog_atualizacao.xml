<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#3b1b0d">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ATUALIZAÇÃO"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#4cff00"
        android:fontFamily="monospace"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@+id/txtVersaoNova"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#f0e6c5"
        android:fontFamily="monospace"
        android:layout_marginBottom="12dp" />

    <TextView
        android:id="@+id/txtChangelog"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="14sp"
        android:textColor="#c4b08a"
        android:fontFamily="monospace"
        android:layout_marginBottom="24dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <Button
            android:id="@+id/btnDepois"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="DEPOIS"
            android:textColor="#ffffff"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:background="#5a3a1a"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/btnAtualizar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="ATUALIZAR"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:background="#4cff00"
            android:textColor="#1a1a2e" />

    </LinearLayout>

</LinearLayout>