<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#3b1b0d">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ATUALIZAÇÃO"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#4cff00"
        android:fontFamily="monospace"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="DISPONÍVEL!"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#4cff00"
        android:fontFamily="monospace"
        android:layout_marginBottom="24dp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:background="#5a3a1a"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@+id/textViewMensagem"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#f0e6c5"
        android:textSize="14sp"
        android:fontFamily="monospace"
        android:layout_marginBottom="24dp" />

    <Button
        android:id="@+id/btnAtualizar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="ATUALIZAR"
        android:textStyle="bold"
        android:fontFamily="monospace"
        android:background="#4cff00"
        android:textColor="#1a1a2e"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btnSair"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="SAIR"
        android:textStyle="bold"
        android:fontFamily="monospace"
        android:background="#5a3a1a"
        android:textColor="#ffffff" />

</LinearLayout>
