<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#3b1b0d">

    <!-- Header estilo Minecraft -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:background="#6b3a1f"
        android:elevation="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MINECRAFT"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:textColor="#4cff00"
                    android:fontFamily="monospace"
                    android:shadowColor="#000000"
                    android:shadowDx="3"
                    android:shadowDy="3"
                    android:shadowRadius="1" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="IMPORTER"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#ffffff"
                    android:fontFamily="monospace"
                    android:shadowColor="#000000"
                    android:shadowDx="2"
                    android:shadowDy="2"
                    android:shadowRadius="1"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <ImageButton
                android:id="@+id/btnDownload"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_download"
                android:background="#5a3a1a"
                android:padding="8dp"
                android:scaleType="fitCenter" />

            <ImageButton
                android:id="@+id/btnMenu"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_whatsapp"
                android:background="#5a3a1a"
                android:padding="8dp"
                android:scaleType="fitCenter"
                android:layout_marginStart="8dp" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:background="#4cff00"
            android:layout_marginTop="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Texturas • Addons • Skins • Mapas"
            android:textSize="12sp"
            android:textColor="#c4b08a"
            android:fontFamily="monospace"
            android:layout_marginTop="4dp" />

    </LinearLayout>

    <!-- Título da lista -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="8dp"
        android:gravity="center_vertical">

        <View
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="#4cff00"
            android:layout_marginEnd="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ARQUIVOS ENCONTRADOS"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#f0e6c5"
            android:fontFamily="monospace" />

    </LinearLayout>

    <!-- ListView -->
    <ListView
        android:id="@+id/listViewArquivos"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#2b1709"
        android:divider="#5a3a1a"
        android:dividerHeight="2dp"
        android:padding="8dp"
        android:cacheColorHint="#2b1709" />

    <!-- Rodapé -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp"
        android:background="#4a2a10"
        android:gravity="center">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Clique no arquivo para importar"
            android:textSize="11sp"
            android:textColor="#8b7355"
            android:fontFamily="monospace" />

    </LinearLayout>

</LinearLayout>
