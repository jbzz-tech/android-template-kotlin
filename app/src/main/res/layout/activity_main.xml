<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="16dp">

    <TextView
        android:id="@+id/tvSaldo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Saldo: R$ 0,00"
        android:textSize="32sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/tvRedeAtual"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Rede atual: ADMOB"
        android:textSize="14sp"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@+id/tvAnuncios"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Anúncios assistidos: 0/100"
        android:textSize="18sp"
        android:layout_marginBottom="32dp" />

    <Button
        android:id="@+id/btnAssistirAnuncio"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Assistir Anúncio"
        android:textSize="18sp"
        android:padding="16dp"
        android:layout_marginBottom="16dp" />

    <Button
        android:id="@+id/btnSacar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Saldo insuficiente"
        android:textSize="18sp"
        android:padding="16dp"
        android:enabled="false" />

</LinearLayout>
